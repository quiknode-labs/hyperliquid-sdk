{
  "name": "@quicknode/hyperliquid-sdk",
  "version": "0.1.0",
  "description": "Community SDK for Hyperliquid. One line to place orders, zero ceremony. HyperCore, HyperEVM, WebSocket and gRPC streams. Not affiliated with Hyperliquid Foundation.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "example": "tsx --tsconfig tsconfig.examples.json",
    "test:examples": "for f in examples/*.ts; do echo \"Testing $(basename $f)...\"; tsx --tsconfig tsconfig.examples.json \"$f\" --help 2>/dev/null || timeout 2 tsx --tsconfig tsconfig.examples.json \"$f\" 2>&1 | head -5; done",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "hyperliquid",
    "trading",
    "crypto",
    "defi",
    "perpetuals",
    "spot",
    "orderbook",
    "websocket",
    "grpc",
    "evm",
    "quicknode"
  ],
  "author": "QuickNode <support@quicknode.com>",
  "license": "MIT",
  "homepage": "https://hyperliquidapi.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/quiknode-labs/hyperliquid-sdk"
  },
  "bugs": {
    "url": "https://github.com/quiknode-labs/hyperliquid-sdk/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ethers": "^6.11.0",
    "ws": "^8.16.0",
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  }
}
